<Page x:Class="CatSpeak.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CatSpeak.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage">

    <StackPanel VerticalAlignment="Center" Width="300" Margin="20">
        <TextBlock Text="Логин" FontSize="18"/>
        <TextBox x:Name="tbLogin" Margin="0,5,0,15"/>
        <TextBlock Text="Пароль" FontSize="18"/>
        <PasswordBox x:Name="pbPassword" Margin="0,5,0,15"/>
        <Button Content="Войти" Click="BtnLogin_Click" Background="#20B2AA"/>
        <Button Content="Регистрация" Click="BtnReg_Click" Background="Gray"/>
        <TextBlock x:Name="tbError" Foreground="Red" Margin="0,10" TextAlignment="Center"/>
    </StackPanel>
</Page>

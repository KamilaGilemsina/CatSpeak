<Page x:Class="CatSpeak.Pages.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CatSpeak.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CatalogPage" Loaded="Page_Loaded">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="tbSearch" Grid.Row="0" Margin="5,0,5,10" 
                 TextChanged="TbSearch_TextChanged"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="icCats">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#20B2AA" BorderThickness="1" 
                                CornerRadius="15" Background="White" 
                                Width="250" Margin="10" Padding="10"
                                Effect="{StaticResource ShadowEffect}">
                            <StackPanel>
                                <Image Source="/Images/iconCat.png" Width="100" Height="100" 
                                       Stretch="UniformToFill" Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" 
                                           FontSize="20" TextAlignment="Center"/>
                                <TextBlock Text="{Binding Breed}" FontSize="12" 
                                           Foreground="#2F4F4F" TextAlignment="Center"/>
                                <TextBlock Text="{Binding Dialect, StringFormat='Диалект: {0}'}" 
                   FontSize="12" Foreground="#20B2AA" TextAlignment="Center"/>
                                <TextBlock Text="{Binding Mood, StringFormat='Настроение: {0}'}" 
                   FontSize="12" Foreground="#20B2AA" TextAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                                    <TextBlock Text="⭐ " Foreground="Gold" FontSize="14"/>
                                    <TextBlock x:Name="tbRating" Text="{Binding Rating, FallbackValue=4.5}" FontSize="14"/>
                                </StackPanel>

                                <Button x:Name="btnOrder" Content="📝 Заказать перевод" 
                                        Click="BtnOrder_Click" Tag="{Binding Id}" 
                                        Margin="0,10,0,0" Background="#20B2AA"/>
                                <Button x:Name="btnDetails" Content="🔍 Подробнее" 
                                        Click="BtnDetails_Click" Tag="{Binding Id}" 
                                        Margin="0,5,0,0" Background="Gray"/>
                                <Button x:Name="btnEdit" Content="✏️ Редактировать" 
                                        Click="BtnEdit_Click" Tag="{Binding Id}" 
                                        Margin="0,5,0,0" Background="#2E8B57"/>
                                <Button x:Name="btnDelete" Content="🗑️ Удалить" 
                                        Click="BtnDelete_Click" Tag="{Binding Id}" 
                                        Margin="0,5,0,0" Background="DarkRed"/>
                                <Button x:Name="btnManageStatus" Content="📊 Статистика диалекта" 
                                        Click="BtnManageStatus_Click" Tag="{Binding Id}" 
                                        Margin="0,5,0,0" Background="#FF8C00"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>

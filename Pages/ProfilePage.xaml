<Page x:Class="CatSpeak.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CatSpeak.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProfilePage">

    <ScrollViewer>
        <StackPanel Margin="15">
            <Image x:Name="imgAvatar" Width="100" Height="100" Stretch="UniformToFill" Margin="0,0,0,10"/>
            <Button Content="Выбрать аватар" Click="BtnSelectAvatar_Click" Margin="0,5"/>
            <TextBlock Text="Логин:" Margin="0,10,0,0"/>
            <TextBox x:Name="tbLogin" IsReadOnly="True"/>
            <TextBlock Text="Полное имя:"/>
            <TextBox x:Name="tbFullName"/>
            <TextBlock Text="Новый пароль:"/>
            <PasswordBox x:Name="pbPassword"/>
            <Button Content="Сохранить изменения" Click="BtnSave_Click" Margin="0,20,0,5"/>
            <TextBlock Text="Мои заказы" FontWeight="Bold" FontSize="18" Margin="0,20,0,5"/>
            <ListBox x:Name="lvOrders" Height="200" DisplayMemberPath="Id"/>
        </StackPanel>
    </ScrollViewer>
</Page>

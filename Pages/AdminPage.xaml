<Page x:Class="CatSpeak.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CatSpeak.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdminPage">

    <TabControl Margin="10">
        <TabItem Header="Пользователи">
            <ScrollViewer VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Hidden">
                <StackPanel>
                    <Button Content="Добавить пользователя" Click="BtnAddUser_Click" Margin="5"/>
                    <ListBox x:Name="lvUsers">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Login}" Width="120"/>
                                    <TextBlock Text="{Binding FullName}" Width="150"/>
                                    <Button Content="Редактировать" Tag="{Binding Id}" Click="BtnEditUser_Click"/>
                                    <Button Content="Удалить" Tag="{Binding Id}" Click="BtnDeleteUser_Click" Margin="5,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</Page>

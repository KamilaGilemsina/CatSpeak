<Window x:Class="CatSpeak.Windows.CompleteOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CatSpeak.Windows"
        mc:Ignorable="d"
        Title="CompleteOrderWindow" Height="450" Width="800">
    <StackPanel Margin="10">
        <TextBlock Text="Заказ №" x:Name="tbOrderId" FontWeight="Bold"/>
        <TextBlock Text="Перевод на человеческий:"/>
        <TextBox x:Name="tbTranslation" TextWrapping="Wrap" Height="100"/>
        <Button Content="Сохранить" Click="BtnSave_Click" Margin="0,15,0,0"/>
        <Button Content="Отмена" Click="BtnCancel_Click"/>
    </StackPanel>
</Window>

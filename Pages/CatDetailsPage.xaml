<Page x:Class="CatSpeak.Pages.CatDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CatSpeak.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CatDetailsPage">

    <ScrollViewer>
        <StackPanel Margin="15">
            <TextBlock x:Name="tbName" FontSize="28" FontWeight="Bold" TextAlignment="Center"/>
            <TextBlock x:Name="tbBreed" FontSize="16" Margin="0,10,0,0"/>
            <TextBlock x:Name="tbDialect" FontSize="16"/>
            <TextBlock x:Name="tbMood" FontSize="16"/>
            <TextBlock x:Name="tbOwner" FontSize="16"/>
            <TextBlock Text="📜 История заказов" FontWeight="Bold" FontSize="20" Margin="0,20,0,10"/>
            <ListBox x:Name="lvOrders" Height="200">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="3">
                            <TextBlock Text="{Binding OrderDate, StringFormat='dd.MM.yyyy'}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Status}"/>
                            <TextBlock Text="{Binding FinalTranslation}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </ScrollViewer>
</Page>

<Window x:Class="CatSpeak.Windows.EditPhraseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CatSpeak.Windows"
        mc:Ignorable="d"
        Title="EditPhraseWindow" Height="450" Width="800">
    <StackPanel Margin="10">
        <TextBlock Text="Диалект кошки:"/>
        <ComboBox x:Name="cmbDialect" Margin="0,5,0,10">
            <ComboBoxItem Content="Дворовый"/>
            <ComboBoxItem Content="Сиамский"/>
            <ComboBoxItem Content="Британский"/>
            <ComboBoxItem Content="Мейн-кун"/>
            <ComboBoxItem Content="Сфинкс"/>
        </ComboBox>

        <TextBlock Text="Звук (мяуканье):"/>
        <TextBox x:Name="tbMeowSound" Margin="0,5,0,10"/>

        <TextBlock Text="Перевод на человеческий:"/>
        <TextBox x:Name="tbHumanTranslation" TextWrapping="Wrap" Height="80" Margin="0,5,0,10"/>

        <TextBlock Text="Уровень опасности (1–5):"/>
        <ComboBox x:Name="cmbDangerLevel" Margin="0,5,0,10">
            <ComboBoxItem Content="1"/>
            <ComboBoxItem Content="2"/>
            <ComboBoxItem Content="3"/>
            <ComboBoxItem Content="4"/>
            <ComboBoxItem Content="5"/>
        </ComboBox>

        <Button Content="Сохранить" Click="BtnSave_Click" Margin="0,20,0,5" Background="#20B2AA" Foreground="White"/>
        <Button Content="Отмена" Click="BtnCancel_Click" Background="Gray"/>
    </StackPanel>
</Window>

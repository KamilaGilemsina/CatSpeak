<Page x:Class="CatSpeak.Pages.LinguistPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CatSpeak.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LinguistPage">

    <TabControl Margin="10">
        <TabItem Header="Мои заказы">
            <ListBox x:Name="lvMyOrders">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Id}" Width="50"/>
                            <TextBlock Text="{Binding Cat.Name}" Width="120"/>
                            <TextBlock Text="{Binding Status}" Width="100"/>
                            <Button Content="Завершить" Click="BtnCompleteOrder_Click" Tag="{Binding Id}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </TabItem>
        <TabItem Header="Доступные заказы">
            <ListBox x:Name="lvAvailableOrders">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Id}" Width="50"/>
                            <TextBlock Text="{Binding Cat.Name}" Width="120"/>
                            <Button Content="Принять" Click="BtnAcceptOrder_Click" Tag="{Binding Id}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </TabItem>
        <TabItem Header="Словарь фраз">
            <ScrollViewer>
                <StackPanel>
                    <Button Content="Добавить фразу" Click="BtnAddPhrase_Click" Margin="5"/>
                    <ListBox x:Name="lvPhrases" DisplayMemberPath="HumanTranslation"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</Page>

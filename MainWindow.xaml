<Window x:Class="CatSpeak.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CatSpeak"
        mc:Ignorable="d"
        Title="Агентство перевода кошачьего языка" Height="600" Width="900"
        Background="#F5FFFA">
    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E0FFFF"/>
            <Setter Property="Foreground" Value="#2F4F4F"/>
            <Setter Property="FontFamily" Value="/Fonts/#Kalam"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="BorderBrush" Value="#20B2AA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="10" Padding="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#20B2AA" CornerRadius="0,0,20,20" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Ellipse Width="50" Height="50" Margin="0,0,15,0">
                    <Ellipse.Fill>
                        <ImageBrush ImageSource="/Images/icon.png"/>
                    </Ellipse.Fill>
                </Ellipse>
                <StackPanel>
                    <TextBlock Text="🐾 CatSpeak Agency 🐾" FontSize="28" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Перевод мяу-языка на человеческий" FontSize="14" Foreground="#E0FFFF"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,10,10,0">
                <Button x:Name="btnCatalog" Content="📋 Каталог кошек" Style="{StaticResource MenuButtonStyle}" Click="btnCatalog_Click"/>
                <Button x:Name="btnProfile" Content="👤 Мой профиль" Style="{StaticResource MenuButtonStyle}" Click="btnProfile_Click"/>
                <Button x:Name="btnAdmin" Content="⚙️ Админ-панель" Style="{StaticResource MenuButtonStyle}" Click="btnAdmin_Click"/>
                <Button x:Name="btnLinguist" Content="🗣️ Лингвист-фелинолог" Style="{StaticResource MenuButtonStyle}" Click="btnLinguist_Click"/>
                <Button x:Name="btnExit" Content="🚪 Выход" Style="{StaticResource MenuButtonStyle}" Click="btnExit_Click"/>
            </StackPanel>

            <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>

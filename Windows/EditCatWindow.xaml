<Window x:Class="CatSpeak.Windows.EditCatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CatSpeak.Windows"
        mc:Ignorable="d"
        Title="EditCatWindow" Height="450" Width="800">
    <StackPanel Margin="10">
        <TextBlock Text="Имя кошки:"/>
        <TextBox x:Name="tbName" Margin="0,5,0,10"/>

        <TextBlock Text="Порода:"/>
        <TextBox x:Name="tbBreed" Margin="0,5,0,10"/>

        <TextBlock Text="Диалект:"/>
        <ComboBox x:Name="cmbDialect" Margin="0,5,0,10">
            <ComboBoxItem Content="Дворовый"/>
            <ComboBoxItem Content="Сиамский"/>
            <ComboBoxItem Content="Британский"/>
            <ComboBoxItem Content="Мейн-кун"/>
            <ComboBoxItem Content="Сфинкс"/>
        </ComboBox>

        <TextBlock Text="Настроение:"/>
        <ComboBox x:Name="cmbMood" Margin="0,5,0,10">
            <ComboBoxItem Content="Голоден"/>
            <ComboBoxItem Content="Захват мира"/>
            <ComboBoxItem Content="Агрессивен"/>
            <ComboBoxItem Content="Игрив"/>
            <ComboBoxItem Content="Сонлив"/>
        </ComboBox>

        <TextBlock Text="Имя владельца:"/>
        <TextBox x:Name="tbOwnerName" Margin="0,5,0,10"/>

        <TextBlock Text="URL фото (необязательно):"/>
        <TextBox x:Name="tbPhotoUrl" Margin="0,5,0,10"/>

        <Button Content="Сохранить" Click="BtnSave_Click" Margin="0,20,0,5" Background="#20B2AA" Foreground="White"/>
        <Button Content="Отмена" Click="BtnCancel_Click" Background="Gray"/>
    </StackPanel>
</Window>
